# Astro-generated JS/CSS have content hashes in filenames — cache aggressively
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Images and media — cache for 30 days
/media/*
  Cache-Control: public, max-age=2592000

# Favicon — cache for 7 days
/favicon.*
  Cache-Control: public, max-age=604800

# HTML pages — allow CDN to cache briefly, always revalidate
/*
  Cache-Control: public, max-age=0, must-revalidate
