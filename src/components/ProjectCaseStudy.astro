---
import ProjectMedia from './ProjectMedia.astro';
import TechSpecs from './TechSpecs.astro';

interface Props {
	title: string;
	domain: string;
	api: string;
	category: string;
	year: number;
	summary: string;
	role?: string;
	problem?: string;
	approach?: string[];
	outcomes?: string[];
	engine: string;
	features: string[];
	performanceMetrics?: string[];
	externalUrl?: string;
	youtubeUrl?: string;
	images?: string[];
	Content: any;
}

const {
	title,
	domain,
	api,
	category,
	year,
	summary,
	role,
	problem,
	approach = [],
	outcomes = [],
	engine,
	features,
	performanceMetrics = [],
	externalUrl,
	youtubeUrl,
	images = [],
	Content
} = Astro.props as Props;

const hasStructuredStory = Boolean(problem || approach.length || outcomes.length);
---

<template class="atlas-island-template">
	<div class="space-y-5">
		<div class="flex flex-wrap items-start justify-between gap-4">
			<div class="max-w-3xl">
				<p class="mono text-[10px] uppercase tracking-[0.14em] text-signal">Case study</p>
				<h3 class="mt-2 text-3xl font-semibold leading-tight text-paper md:text-4xl">{title}</h3>
				<p class="mt-3 text-sm leading-relaxed text-muted md:text-base">{summary}</p>
			</div>
			<div class="flex flex-wrap items-center gap-2">
				<span class="atlas-chip">{domain}</span>
				<span class="atlas-chip">{api}</span>
				<span class="atlas-chip">{category}</span>
				<span class="atlas-chip">{year}</span>
			</div>
		</div>

		<div class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
			<div class="space-y-4">
				{role && (
					<section class="case-study-block">
						<p class="case-study-label">Ownership</p>
						<p class="mt-2 text-sm leading-relaxed text-paper">{role}</p>
					</section>
				)}

				{problem && (
					<section class="case-study-block">
						<p class="case-study-label">Problem</p>
						<p class="mt-2 text-sm leading-relaxed text-muted">{problem}</p>
					</section>
				)}

				{approach.length > 0 && (
					<section class="case-study-block">
						<p class="case-study-label">Approach</p>
						<ul class="case-study-list">
							{approach.map((item) => <li>{item}</li>)}
						</ul>
					</section>
				)}

				{outcomes.length > 0 && (
					<section class="case-study-block case-study-block-accent">
						<p class="case-study-label">Outcome</p>
						<ul class="case-study-list">
							{outcomes.map((item) => <li>{item}</li>)}
						</ul>
					</section>
				)}

				<div class="atlas-expanded-body soft-panel border-1 border-line bg-raised p-4 text-sm leading-relaxed text-muted">
					{hasStructuredStory && <p class="case-study-label mb-3">Project notes</p>}
					<Content />
				</div>

				<TechSpecs
					title="Technical profile"
					engine={engine}
					api={api}
					features={features}
					performanceMetrics={performanceMetrics}
				/>
			</div>

			<div class="soft-panel h-fit border-1 border-line bg-raised p-3">
				<ProjectMedia title={title} youtubeUrl={youtubeUrl} images={images} />
			</div>
		</div>

		{externalUrl && (
			<p>
				<a href={externalUrl} target="_blank" rel="noreferrer" class="mono text-[11px] font-medium uppercase tracking-[0.14em] underline decoration-signal underline-offset-4 hover:text-signal">
					Open project link ↗
				</a>
			</p>
		)}
	</div>
</template>
