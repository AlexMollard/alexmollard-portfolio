---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Alex Mollard | Graphics Engineer',
	description = 'Portfolio focused on rendering systems, real-time graphics, and engine architecture.'
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-vanilla text-ash">
		<div class="pointer-events-none fixed inset-0 -z-10">
			<div class="absolute -left-32 top-24 h-72 w-72 rounded-full bg-olive/20 blur-3xl"></div>
			<div class="absolute -right-16 top-10 h-80 w-80 rounded-full bg-copper/20 blur-3xl"></div>
			<div class="absolute bottom-0 left-1/3 h-72 w-72 rounded-full bg-cream/40 blur-3xl"></div>
		</div>
		<div class="surface-grid mx-auto max-w-6xl px-6 py-10 md:px-10 md:py-14">
			<slot />
		</div>
	</body>
</html>
