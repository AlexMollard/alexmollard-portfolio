---
import { getCollection, render } from 'astro:content';
import ProjectMedia from '../components/ProjectMedia.astro';
import TechSpecs from '../components/TechSpecs.astro';
import Layout from '../layouts/Layout.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const inferDomain = (project: (typeof projects)[number]) => {
	const corpus = `${project.data.title} ${project.data.summary} ${project.data.features.join(' ')}`.toLowerCase();
	if (corpus.includes('network') || corpus.includes('enet') || corpus.includes('udp')) return 'Networking';
	if (corpus.includes('audio') || corpus.includes('openal')) return 'Tools';
	if (corpus.includes('vulkan') || corpus.includes('render') || corpus.includes('pbr') || corpus.includes('shader')) return 'Graphics';
	if (corpus.includes('engine')) return 'Engine';
	if (corpus.includes('noise') || corpus.includes('fluid') || corpus.includes('marching')) return 'Research';
	return 'Gameplay';
};

const atlasProjects = await Promise.all(
	projects.map(async (project) => {
		const { Content } = await render(project);

		return {
			project,
			domain: inferDomain(project),
			year: project.data.date.getFullYear(),
			Content
		};
	})
);

const domains = [...new Set(atlasProjects.map((item) => item.domain))];
const categories = [...new Set(atlasProjects.map((item) => item.project.data.category))];
const apis = [...new Set(atlasProjects.map((item) => item.project.data.api))];
const years = [...new Set(atlasProjects.map((item) => item.year))].sort((a, b) => b - a);
---

<Layout
	title="Alex Mollard | Graphics Engineer"
	description="I build graphics, networking, and gameplay systems in C++ with a focus on practical engine architecture and shipped game features."
>
	<header class="reveal-in relative left-1/2 -mx-[50dvw] -mt-10 w-[100dvw] md:-mt-14">
		<section class="hero-stage min-h-[100svh] w-[100dvw]">
			<div class="grid min-h-[100svh] w-full grid-cols-1 lg:grid-cols-[minmax(30rem,0.88fr)_minmax(0,1.12fr)]">
				<div class="hero-copy flex min-h-[58svh] flex-col justify-between px-6 pb-8 pt-10 sm:px-10 sm:pb-10 lg:min-h-[100svh] lg:px-16 lg:pb-12 lg:pt-14">
					<div class="flex items-center justify-between gap-4 border-b border-line pb-4">
						<p class="mono text-[10px] uppercase tracking-[0.16em] text-muted">Alex Mollard / Portfolio</p>
						<p class="mono text-[10px] uppercase tracking-[0.16em] text-muted">Melbourne, AU</p>
					</div>

					<div class="my-14 max-w-2xl lg:my-10">
						<p class="mono text-[11px] uppercase tracking-[0.16em] text-signal">Graphics + systems engineer</p>
						<h1 class="mt-5 text-[clamp(3.5rem,7vw,7.4rem)] font-medium leading-[0.82] text-paper">
							Alex<br />Mollard
						</h1>
						<p class="mt-8 max-w-xl text-lg leading-relaxed text-muted md:text-xl">
							I build rendering, networking, and engine tools—the awkward, useful parts that make the rest of a game work.
						</p>
					</div>

					<div>
						<div class="grid gap-px border border-line bg-line sm:grid-cols-3">
							<div class="bg-ground p-3">
								<p class="mono text-[9px] uppercase tracking-[0.12em] text-muted">Now</p>
								<p class="mt-1 text-sm text-paper">Big Ant Studios</p>
							</div>
							<div class="bg-ground p-3">
								<p class="mono text-[9px] uppercase tracking-[0.12em] text-muted">Working in</p>
								<p class="mt-1 text-sm text-paper">C++ / Vulkan</p>
							</div>
							<div class="bg-ground p-3">
								<p class="mono text-[9px] uppercase tracking-[0.12em] text-muted">Interested in</p>
								<p class="mt-1 text-sm text-paper">Systems you can see</p>
							</div>
						</div>
						<div class="mt-3 grid grid-cols-2 gap-3">
							<a href="mailto:alexmollard@protonmail.com" class="group border border-signal bg-signal px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-ground transition hover:bg-paper">
								<span class="flex items-center justify-between"><span>Contact</span><span aria-hidden="true">↗</span></span>
							</a>
							<a href="#projects" class="group border border-line px-4 py-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-paper transition hover:border-signal">
								<span class="flex items-center justify-between"><span>View work</span><span aria-hidden="true">↓</span></span>
							</a>
						</div>
					</div>
				</div>

				<figure class="hero-visual overflow-hidden">
					<img
						src="/media/hobbies/pbr-renderer/pbr-renderer-1.webp"
						alt="A physically based material rendered inside Alex's custom engine editor"
						class="hero-image"
					/>
					<figcaption class="hero-caption mono text-[10px] uppercase leading-relaxed tracking-[0.1em] text-muted">
						<span class="block text-paper">Personal renderer / material pass</span>
						C++ · Engine UI · PBR lighting
					</figcaption>
				</figure>
			</div>
		</section>
	</header>

	<main id="projects" class="relative left-1/2 -mx-[50dvw] w-[100dvw] px-6 py-20 md:px-10 md:py-28 lg:px-14">
		<div class="mx-auto max-w-[104rem]">
			<header class="section-rule mb-12 grid gap-6 lg:grid-cols-[18rem_minmax(0,1fr)] lg:items-end">
				<p class="mono text-[10px] uppercase tracking-[0.16em] text-muted">Work archive / {atlasProjects.length} entries</p>
				<div class="grid gap-5 md:grid-cols-[minmax(0,1fr)_minmax(18rem,0.65fr)] md:items-end">
					<h2 class="text-5xl font-medium leading-none text-paper md:text-7xl">Built, shipped,<br />or learned from.</h2>
					<p class="max-w-xl text-base leading-relaxed text-muted">A mix of shipped games, renderer work, engine experiments, and small tools. Some are polished; some exist because I needed to understand the problem properly.</p>
				</div>
			</header>

			<section class="grid gap-6 lg:grid-cols-[18rem_minmax(0,1fr)]">
				<aside class="soft-panel h-fit border-1 border-line bg-surface p-4 md:p-5 lg:sticky lg:top-6">
					<div class="flex items-center justify-between gap-3 lg:hidden">
						<div>
							<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Project index</p>
							<p class="mt-1 text-sm text-muted">Filter the archive</p>
						</div>
						<button id="atlas-filters-toggle" type="button" class="atlas-chip shrink-0" aria-expanded="false" aria-controls="atlas-filters-panel">Show Filters</button>
					</div>
					<div id="atlas-filters-panel" class="mt-4 hidden space-y-4 lg:mt-0 lg:block">
						<div>
							<label for="atlas-search" class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Search</label>
							<input id="atlas-search" type="text" placeholder="title, feature, summary" class="mt-2 w-full border-1 border-line bg-ground px-3 py-2 text-sm text-paper placeholder:text-muted/60 focus:border-signal focus:outline-none" />
						</div>

						<div>
							<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Sort</p>
							<select id="atlas-sort" class="atlas-select mt-2 w-full border-1 border-line bg-ground px-3 py-2 text-sm text-paper focus:border-signal focus:outline-none">
								<option value="newest">Newest</option>
								<option value="oldest">Oldest</option>
								<option value="title">Title A-Z</option>
							</select>
						</div>

						<div>
							<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Domain</p>
							<div class="mt-2 flex flex-wrap gap-2" data-filter-group="domain">
								<button class="atlas-chip atlas-chip-active" data-filter="all" type="button">All</button>
								{domains.map((domain) => <button class="atlas-chip" data-filter={domain} type="button">{domain}</button>)}
							</div>
						</div>

						<div>
							<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Type</p>
							<div class="mt-2 flex flex-wrap gap-2" data-filter-group="category">
								<button class="atlas-chip atlas-chip-active" data-filter="all" type="button">All</button>
								{categories.map((category) => <button class="atlas-chip" data-filter={category} type="button">{category}</button>)}
							</div>
						</div>

						<div>
							<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">API</p>
							<div class="mt-2 flex flex-wrap gap-2" data-filter-group="api">
								<button class="atlas-chip atlas-chip-active" data-filter="all" type="button">All</button>
								{apis.map((api) => <button class="atlas-chip" data-filter={api} type="button">{api}</button>)}
							</div>
						</div>

						<div>
							<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Timeline</p>
							<div class="mt-2 flex flex-wrap gap-2" data-filter-group="year">
								<button class="atlas-chip atlas-chip-active" data-filter="all" type="button">All</button>
								{years.map((year) => <button class="atlas-chip" data-filter={String(year)} type="button">{year}</button>)}
							</div>
						</div>

						<button id="atlas-reset" type="button" class="atlas-chip w-full">Reset Filters</button>
					</div>
				</aside>

				<div class="space-y-5">
					<div id="atlas-grid" class="grid gap-5 xl:grid-cols-2">
						{atlasProjects.map(({ project, domain, year, Content }, projectIndex) => {
							const previewImage = project.data.media_images?.[0];

							return (
								<article
									class="atlas-card soft-panel card-pop overflow-hidden border-1 border-line bg-surface"
									data-title={project.data.title.toLowerCase()}
									data-summary={project.data.summary.toLowerCase()}
									data-features={project.data.features.join(' ').toLowerCase()}
									data-domain={domain}
									data-category={project.data.category}
									data-api={project.data.api}
									data-year={String(year)}
									data-ts={String(project.data.date.getTime())}
								>
									{previewImage && (
										<div class="relative h-44 overflow-hidden border-b border-line">
											<img src={previewImage} alt={`${project.data.title} preview`} class="h-full w-full object-cover" loading="lazy" />
										</div>
									)}
									<div class="space-y-3 p-5">
										<div class="flex items-start justify-between gap-3">
											<div class="flex flex-wrap items-center gap-2">
												<span class="atlas-chip">{domain}</span>
												<span class="atlas-chip">{project.data.api}</span>
												<span class="atlas-chip">{project.data.category}</span>
												<span class="atlas-chip">{year}</span>
											</div>
											<p class="mono shrink-0 text-[10px] tracking-[0.12em] text-signal">/{String(projectIndex + 1).padStart(2, '0')}</p>
										</div>
										<h3 class="text-2xl font-semibold leading-tight text-paper">{project.data.title}</h3>
										<p class="text-sm leading-relaxed text-muted">{project.data.summary}</p>
										<div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-start">
											<p class="text-sm leading-relaxed text-muted/85">{project.data.features.slice(0, 3).join(' · ')}</p>
											<div class="flex items-center justify-end gap-2">
												<button
													type="button"
													class="atlas-expand-toggle atlas-chip"
													aria-expanded="false"
												>
													More Info
												</button>
											</div>
										</div>
									</div>

									<template class="atlas-island-template">
										<div class="space-y-4">
											<div class="flex flex-wrap items-start justify-between gap-3">
												<div>
													<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Project detail</p>
													<h3 class="mt-1 text-3xl font-semibold leading-tight text-paper">{project.data.title}</h3>
												</div>
												<div class="flex flex-wrap items-center gap-2">
													<span class="atlas-chip">{domain}</span>
													<span class="atlas-chip">{project.data.api}</span>
													<span class="atlas-chip">{project.data.category}</span>
													<span class="atlas-chip">{year}</span>
												</div>
											</div>

										<div class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
											<div class="space-y-4">
												<div class="atlas-expanded-body soft-panel border-1 border-line bg-raised p-4 text-sm leading-relaxed text-muted">
													<Content />
												</div>
												{project.data.role && (
													<div class="soft-panel border-1 border-line bg-raised p-4 text-sm leading-relaxed text-muted">
														<p><span class="font-semibold text-paper">Role:</span> {project.data.role}</p>
													</div>
												)}
													<TechSpecs
														title="Project Specs"
														engine={project.data.engine}
														api={project.data.api}
														features={project.data.features}
														performanceMetrics={project.data.performance_metrics}
												/>
											</div>
											<div class="soft-panel border-1 border-line bg-raised p-3">
												<ProjectMedia title={project.data.title} youtubeUrl={project.data.youtube_url} images={project.data.media_images} />
											</div>
											</div>

											{project.data.external_url && (
												<p>
													<a href={project.data.external_url} target="_blank" rel="noreferrer" class="mono text-[12px] font-medium uppercase tracking-[0.14em] underline decoration-signal underline-offset-4 hover:text-signal">
														Open Project Link
													</a>
												</p>
											)}
										</div>
									</template>
								</article>
							);
						})}
					</div>

					<div class="flex items-center justify-between gap-4">
						<p id="atlas-empty" class="hidden text-sm text-muted">No projects match the current filter set.</p>
						<button id="atlas-load-more" type="button" class="atlas-chip">Load More</button>
					</div>
				</div>
			</section>

			<div id="atlas-island-overlay" class="atlas-island-overlay hidden" aria-hidden="true">
				<div class="atlas-island-shell soft-panel border-1 border-line bg-raised">
					<div class="flex items-center justify-between gap-3 border-b border-line px-4 py-3 md:px-5">
						<p class="mono text-[11px] uppercase tracking-[0.14em] text-muted">Project detail</p>
						<button id="atlas-island-close" type="button" class="atlas-chip">Close</button>
					</div>
					<div id="atlas-island-content" class="max-h-[78dvh] overflow-y-auto p-4 md:p-5"></div>
				</div>
				<div id="atlas-image-preview" class="atlas-image-preview hidden" aria-hidden="true">
					<button id="atlas-image-preview-close" type="button" class="atlas-chip atlas-image-preview-close">Close Preview</button>
					<img id="atlas-image-preview-img" src="" alt="Project media preview" class="atlas-image-preview-img" />
				</div>
			</div>
		</div>

		<script is:inline>
			(() => {
				const cards = Array.from(document.querySelectorAll('.atlas-card'));
				const searchInput = document.getElementById('atlas-search');
				const sortSelect = document.getElementById('atlas-sort');
				const emptyState = document.getElementById('atlas-empty');
				const loadMoreButton = document.getElementById('atlas-load-more');
				const resetButton = document.getElementById('atlas-reset');
				const filtersToggle = document.getElementById('atlas-filters-toggle');
				const filtersPanel = document.getElementById('atlas-filters-panel');
				const groups = Array.from(document.querySelectorAll('[data-filter-group]'));
				const expandToggles = Array.from(document.querySelectorAll('.atlas-expand-toggle'));
				const islandOverlay = document.getElementById('atlas-island-overlay');
				const islandContent = document.getElementById('atlas-island-content');
				const islandClose = document.getElementById('atlas-island-close');
				const imagePreview = document.getElementById('atlas-image-preview');
				const imagePreviewImg = document.getElementById('atlas-image-preview-img');
				const imagePreviewClose = document.getElementById('atlas-image-preview-close');

				if (!cards.length || !searchInput || !sortSelect || !emptyState || !loadMoreButton || !resetButton) return;

				const state = {
					search: '',
					domain: 'all',
					category: 'all',
					api: 'all',
					year: 'all',
					sort: 'newest',
					limit: 6
				};

				const params = new URLSearchParams(window.location.search);
				(['domain', 'category', 'api', 'year', 'sort', 'search']).forEach((key) => {
					const value = params.get(key);
					if (value) state[key] = value;
				});

				searchInput.value = state.search;
				sortSelect.value = state.sort;

				const syncFiltersVisibility = () => {
					if (!filtersToggle || !filtersPanel) return;
					const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
					const isOpen = isDesktop || !filtersPanel.classList.contains('hidden');
					filtersToggle.setAttribute('aria-expanded', String(isOpen));
					filtersToggle.textContent = isOpen ? 'Hide Filters' : 'Show Filters';
				};

				if (filtersToggle && filtersPanel) {
					filtersToggle.addEventListener('click', () => {
						if (window.matchMedia('(min-width: 1024px)').matches) return;
						filtersPanel.classList.toggle('hidden');
						syncFiltersVisibility();
					});

					window.addEventListener('resize', syncFiltersVisibility);
					syncFiltersVisibility();
				}

				const setActiveChip = (groupName, value) => {
					const group = groups.find((node) => node.getAttribute('data-filter-group') === groupName);
					if (!group) return;
					group.querySelectorAll('.atlas-chip').forEach((chip) => {
						const isActive = chip.getAttribute('data-filter') === value;
						chip.classList.toggle('atlas-chip-active', isActive);
					});
				};

				const updateURL = () => {
					const nextParams = new URLSearchParams();
					if (state.search) nextParams.set('search', state.search);
					if (state.domain !== 'all') nextParams.set('domain', state.domain);
					if (state.category !== 'all') nextParams.set('category', state.category);
					if (state.api !== 'all') nextParams.set('api', state.api);
					if (state.year !== 'all') nextParams.set('year', state.year);
					if (state.sort !== 'newest') nextParams.set('sort', state.sort);
					const query = nextParams.toString();
					window.history.replaceState({}, '', query ? `?${query}` : window.location.pathname);
				};

				const apply = () => {
					const search = state.search.trim().toLowerCase();
					const filtered = cards.filter((card) => {
						const haystack = `${card.dataset.title} ${card.dataset.summary} ${card.dataset.features}`;
						const matchesSearch = !search || haystack.includes(search);
						const matchesDomain = state.domain === 'all' || card.dataset.domain === state.domain;
						const matchesCategory = state.category === 'all' || card.dataset.category === state.category;
						const matchesApi = state.api === 'all' || card.dataset.api === state.api;
						const matchesYear = state.year === 'all' || card.dataset.year === state.year;
						return matchesSearch && matchesDomain && matchesCategory && matchesApi && matchesYear;
					});

					filtered.sort((a, b) => {
						if (state.sort === 'title') return (a.dataset.title || '').localeCompare(b.dataset.title || '');
						const delta = Number(b.dataset.ts || 0) - Number(a.dataset.ts || 0);
						return state.sort === 'oldest' ? -delta : delta;
					});

					cards.forEach((card) => card.classList.add('atlas-card-hidden'));
					filtered.forEach((card, index) => {
						card.classList.toggle('atlas-card-hidden', index >= state.limit);
					});

					emptyState.classList.toggle('hidden', filtered.length > 0);
					loadMoreButton.classList.toggle('hidden', filtered.length <= state.limit);

					const grid = document.getElementById('atlas-grid');
					if (grid) {
						filtered.forEach((card) => grid.appendChild(card));
					}

					updateURL();
					setupInfiniteScroll();
				};

				const closeIsland = () => {
					if (!islandOverlay || !islandContent) return;
					if (imagePreview && imagePreviewImg) {
						imagePreview.classList.add('hidden');
						imagePreview.setAttribute('aria-hidden', 'true');
						imagePreviewImg.setAttribute('src', '');
					}
					islandOverlay.classList.add('hidden');
					islandOverlay.setAttribute('aria-hidden', 'true');
					islandContent.innerHTML = '';
					document.body.classList.remove('atlas-island-open');
					expandToggles.forEach((toggle) => {
						toggle.setAttribute('aria-expanded', 'false');
						toggle.textContent = 'More Info';
					});
				};

				const closeImagePreview = () => {
					if (!imagePreview || !imagePreviewImg) return;
					imagePreview.classList.add('hidden');
					imagePreview.setAttribute('aria-hidden', 'true');
					imagePreviewImg.setAttribute('src', '');
				};

				expandToggles.forEach((toggle) => {
					toggle.addEventListener('click', (e) => {
						e.stopPropagation();
						if (!islandOverlay || !islandContent) return;
						const card = toggle.closest('.atlas-card');
						if (!card) return;
						const template = card.querySelector('.atlas-island-template');
						if (!template) return;

						expandToggles.forEach((chip) => {
							chip.setAttribute('aria-expanded', 'false');
							chip.textContent = 'More Info';
						});

						islandContent.innerHTML = '';
						islandContent.appendChild(template.content.cloneNode(true));
						islandOverlay.classList.remove('hidden');
						islandOverlay.setAttribute('aria-hidden', 'false');
						document.body.classList.add('atlas-island-open');

						toggle.setAttribute('aria-expanded', 'true');
						toggle.textContent = 'Opened';
					});
				});

				document.querySelectorAll('.atlas-card').forEach((card) => {
					card.style.cursor = 'pointer';
					card.addEventListener('click', (e) => {
						if (e.target.closest('a')) return;
						const toggle = card.querySelector('.atlas-expand-toggle');
						if (toggle) toggle.click();
					});
				});

				if (islandClose) {
					islandClose.addEventListener('click', closeIsland);
				}

				if (islandContent && imagePreview && imagePreviewImg) {
					islandContent.addEventListener('click', (event) => {
						const target = event.target;
						if (!(target instanceof HTMLImageElement)) return;
						const source = target.getAttribute('src');
						if (!source) return;

						imagePreviewImg.setAttribute('src', source);
						imagePreviewImg.setAttribute('alt', target.getAttribute('alt') || 'Project media preview');
						imagePreview.classList.remove('hidden');
						imagePreview.setAttribute('aria-hidden', 'false');
					});
				}

				if (imagePreviewClose) {
					imagePreviewClose.addEventListener('click', closeImagePreview);
				}

				if (imagePreview) {
					imagePreview.addEventListener('click', (event) => {
						if (event.target === imagePreview) closeImagePreview();
					});
				}

				if (islandOverlay) {
					islandOverlay.addEventListener('click', (event) => {
						if (event.target === islandOverlay) closeIsland();
					});
				}

				document.addEventListener('keydown', (event) => {
					if (event.key !== 'Escape') return;
					if (imagePreview && !imagePreview.classList.contains('hidden')) {
						closeImagePreview();
						return;
					}
					closeIsland();
				});

				groups.forEach((group) => {
					const key = group.getAttribute('data-filter-group');
					if (!key) return;
					setActiveChip(key, state[key]);
					group.querySelectorAll('.atlas-chip').forEach((chip) => {
						chip.addEventListener('click', () => {
							state[key] = chip.getAttribute('data-filter') || 'all';
							state.limit = 6;
							setActiveChip(key, state[key]);
							apply();
						});
					});
				});

				searchInput.addEventListener('input', (event) => {
					state.search = event.target.value;
					state.limit = 6;
					apply();
				});

				sortSelect.addEventListener('change', (event) => {
					state.sort = event.target.value;
					apply();
				});

				loadMoreButton.addEventListener('click', () => {
					state.limit += 6;
					apply();
				});

				resetButton.addEventListener('click', () => {
					state.search = '';
					state.domain = 'all';
					state.category = 'all';
					state.api = 'all';
					state.year = 'all';
					state.sort = 'newest';
					state.limit = 6;
					searchInput.value = '';
					sortSelect.value = 'newest';
					setActiveChip('domain', 'all');
					setActiveChip('category', 'all');
					setActiveChip('api', 'all');
					setActiveChip('year', 'all');
					apply();
				});

				// Infinite scroll: detect when user scrolls near the end
				const setupInfiniteScroll = () => {
					const grid = document.getElementById('atlas-grid');
					if (!grid) return;

					// Remove old sentinel if exists
					const oldSentinel = document.getElementById('atlas-scroll-sentinel');
					if (oldSentinel) oldSentinel.remove();

					// Create sentinel element
					const sentinel = document.createElement('div');
					sentinel.id = 'atlas-scroll-sentinel';
					grid.parentNode?.insertBefore(sentinel, grid.nextSibling);

					// Setup observer
					const observer = new IntersectionObserver((entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting && !loadMoreButton.classList.contains('hidden')) {
								state.limit += 6;
								apply();
							}
						});
					}, { rootMargin: '200px' });

					observer.observe(sentinel);
				};

				apply();
			})();
		</script>
	</main>
</Layout>
